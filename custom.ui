  <property name="styleSheet">
   <string notr="true">
QWidget { background:#e6eaee; }
QFrame#commandBar { background:#f8fafb; border:1px solid #dfe6ee; border-radius:8px; }

/* Boutons plus fins (tactile acceptable) */
QPushButton, QToolButton {
  background:#00BCD4; color:white; border:0; border-radius:8px;
  padding:6px 10px;            /* ↓ padding */
  font-size:13px;
  min-height:36px;             /* ↓ hauteur mini (~36 px) */
}
QPushButton:hover, QToolButton:hover { background:#26C6DA; }
QPushButton:pressed, QToolButton:pressed { background:#008C9E; }

/* Groupes propriété (marges un peu réduites) */
QGroupBox { background:#ffffff; border:1px solid #dfe6ee; border-radius:8px; margin-top:8px; }
QGroupBox::title { subcontrol-origin: margin; left:10px; padding:2px 4px; color:#4b5a6a; }

/* Sliders compacts */
QSlider::groove:horizontal { height:6px; background:#d6d6d6; border:1px solid #bbb; border-radius:3px; }
QSlider::handle:horizontal {
  width:20px; height:20px; background:#00BCD4; border:1px solid #008C9E;
  border-radius:10px; margin:-7px 0;
}

/* Splitter tactile mais plus fin */
QSplitter::handle:horizontal { width:12px; background:#cfd8dc; }

/* Chevrons compacts dans la barre */
QToolButton#chevronLeft, QToolButton#chevronRight {
  min-width:28px; min-height:28px; max-width:28px; max-height:28px;
  font-size:16px; border-radius:14px; background:#e0f7fa; color:#006064;
}
QToolButton#chevronLeft:hover, QToolButton#chevronRight:hover { background:#b2ebf2; }
QToolButton#chevronLeft:pressed, QToolButton#chevronRight:pressed { background:#80deea; }

/* États existants conservés */
QPushButton[gommeMode=&quot;true&quot;] { background:#e1bee7; border:2px solid #8e24aa; }
QPushButton[supprimerMode=&quot;true&quot;] { background:#ffcdd2; border:2px solid #d32f2f; }
QPushButton[deplacerMode=&quot;true&quot;], QPushButton[closeMode=&quot;true&quot;], QPushButton[snapMode=&quot;true&quot;] {
  background:#a0c4ff; border:2px solid #5F7FFF;
}
