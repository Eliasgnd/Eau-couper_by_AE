      <property name="styleSheet">
       <string notr="true">/* ton style de base */
QPushButton {
    background-color: #00BCD4;
    color: white;
    font-size: 14px;
    border: 2px solid #008C9E;
    border-radius: 5px;
    padding: 6px 12px;
}
QPushButton:hover {
    background-color: #26C6DA;
}
QPushButton:pressed {
    background-color: #008C9E;
}

/* nouveau : quand la propriété closeMode vaut true */
QPushButton[closeMode=&quot;true&quot;] {
    background-color: #a0c4ff;
    border: 2px solid #5F7FFF;
}
QPushButton[closeMode=&quot;true&quot;]:hover {
    background-color: #b5d5ff;
}
QPushButton[closeMode=&quot;true&quot;]:pressed {
    background-color: #8fb1ff;
}
</string>
      </property>
      <property name="locale">
       <locale language="French" country="France"/>
      </property>
