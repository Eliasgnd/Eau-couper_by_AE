      <property name="styleSheet">
       <string notr="true">QSlider::groove:horizontal {
    height: 6px;
    background: #d6d6d6;
    border: 1px solid #bbb;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 20px;
    background: #00BCD4;
    border: 1px solid #008C9E;
    border-radius: 10px;
    margin: -5px 0;
}

QSlider::handle:horizontal:hover {
    background: #26C6DA;
}
</string>
